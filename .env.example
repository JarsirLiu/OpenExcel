NODE_ENV=production
PORT=4000
OPENEXCEL_IMAGE=openexcel:local
OPENEXCEL_STORAGE_ROOT=.data/storage

MODEL_BASE_URL=https://your-model-endpoint.example/v1
MODEL_API_KEY=replace-with-your-api-key
MODEL_NAME=your-model-name
MODEL_MAX_RETRIES=2
MODEL_CONTEXT_WINDOW_TOKENS=180000
MODEL_OUTPUT_RESERVE_TOKENS=16000
MODEL_MAX_CONVERSATION_TURNS=20
MODEL_MAX_USER_INPUT_TOKENS=16000
MODEL_TOOL_RESULT_BUDGET_TOKENS=32000
MODEL_TOOL_RESULT_MAX_TOKENS=8000
MODEL_READ_SHEET_DATA_BUDGET_TOKENS=24000
