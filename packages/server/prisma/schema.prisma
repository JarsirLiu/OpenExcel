generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Workbook {
  id        Int      @id @default(autoincrement())
  name      String
  order     Int
  sheets    Sheet[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Sheet {
  id           Int      @id @default(autoincrement())
  workbookId   Int
  name         String
  order        Int
  columns      String
  merges       String   @default("[]")
  rows         String
  uploadedData String?
  workbook     Workbook @relation(fields: [workbookId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
