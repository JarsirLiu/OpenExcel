generator client {
  provider = "prisma-client-js"
  output   = "../generated/postgresql/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workbook {
  id          Int       @id @default(autoincrement())
  publicId    String    @unique
  workspaceId Int
  name        String
  order       Int
  sourceAssetId Int?
  sheets      Sheet[]
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sourceAsset UploadAsset? @relation(fields: [sourceAssetId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId])
  @@index([sourceAssetId])
}

model UploadAsset {
  id               Int        @id @default(autoincrement())
  publicId         String     @unique
  workspaceId      Int
  storageKey       String
  originalFileName String
  detectedFormat   String
  mimeType         String
  sizeBytes        Int
  sha256           String
  workspace        Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workbooks        Workbook[]
  createdAt        DateTime   @default(now())

  @@index([workspaceId])
  @@index([sha256])
}

model User {
  id           Int            @id @default(autoincrement())
  email        String         @unique
  displayName  String
  passwordHash String
  exampleWorkspaceSeededAt DateTime?
  workspaces   Workspace[]
  authSessions AuthSession[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model AuthSession {
  id         Int      @id @default(autoincrement())
  userId     Int
  tokenHash  String   @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  lastSeenAt DateTime?
  userAgent  String?
  ipAddress  String?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Sheet {
  id           Int                     @id @default(autoincrement())
  workbookId   Int
  sheetNo      Int
  name         String
  order        Int
  columns      String                  @db.Text
  merges       String                  @db.Text
  uploadedData String?                 @db.Text
  config       String?                 @db.Text
  workbook     Workbook                @relation(fields: [workbookId], references: [id], onDelete: Cascade)
  sessions     Session[]
  runSnapshots AgentRunSheetSnapshot[]
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  @@unique([workbookId, sheetNo])
  @@index([workbookId, order])
}

model Workspace {
  id          Int        @id @default(autoincrement())
  publicId    String     @unique
  ownerUserId Int
  name        String
  order       Int
  owner       User       @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  workbooks   Workbook[]
  uploadAssets UploadAsset[]
  sessions    Session[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([ownerUserId])
  @@index([order])
}

model Session {
  id           Int        @id @default(autoincrement())
  publicId     String     @unique
  workspaceId  Int
  sheetId      Int?
  name         String
  titleStatus  String   @default("pending")
  chatMessages String?    @default("[]")
  undoRunId    Int?
  workspace    Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sheet        Sheet?     @relation(fields: [sheetId], references: [id], onDelete: SetNull)
  runs         AgentRun[]
  createdAt    DateTime   @default(now())

  @@index([workspaceId])
  @@index([workspaceId, undoRunId])
}

model AgentRun {
  id           Int                     @id @default(autoincrement())
  sessionId    Int
  clientRequestId String?              @unique
  status       String
  model        String?
  systemPrompt String?
  inputText    String?
  outputText   String?
  errorMessage String?
  undoInvalidated Boolean                @default(false)
  revertedAt   DateTime?
  session      Session                 @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  steps        AgentStep[]
  snapshots    AgentRunSheetSnapshot[]
  startedAt    DateTime                @default(now())
  endedAt      DateTime?
}

model AgentStep {
  id        Int      @id @default(autoincrement())
  runId     Int
  type      String
  status    String
  content   String?
  toolName  String?
  input     String?
  output    String?
  order     Int
  run       AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model AgentRunSheetSnapshot {
  id           Int      @id @default(autoincrement())
  runId        Int
  sheetId      Int
  uploadedData String? @db.Text
  config       String? @db.Text
  createdAt    DateTime @default(now())
  run          AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  sheet        Sheet    @relation(fields: [sheetId], references: [id], onDelete: Cascade)

  @@unique([runId, sheetId])
  @@index([runId])
  @@index([sheetId])
}
