{
  "name": "@openexcel/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm db:prepare",
    "prestart": "pnpm db:generate",
    "postinstall": "tsx scripts/prisma-database.ts generate",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "tsx scripts/prisma-database.ts generate",
    "db:migrate": "tsx scripts/prisma-database.ts migrate",
    "db:prepare": "pnpm db:generate && pnpm db:migrate"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^9.1.3",
    "@openexcel/agent": "workspace:*",
    "@openexcel/chat-contracts": "workspace:*",
    "@openexcel/core": "workspace:*",
    "@prisma/client": "6.19.3",
    "ai": "^7.0.4",
    "dotenv": "^16.6.1",
    "fastify": "^5.2.1",
    "prisma": "^6.2.1",
    "tsx": "^4.19.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.6.3",
    "vitest": "^3.2.6"
  }
}
