{
  "name": "@openexcel/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "prisma db push && tsx prisma/seed.ts",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:init": "prisma db push && tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/multipart": "^9.0.3",
    "@iarna/toml": "^2.2.5",
    "@openexcel/agent": "workspace:*",
    "@openexcel/core": "workspace:*",
    "@prisma/client": "6.19.3",
    "ai": "^7.0.4",
    "fastify": "^5.2.1",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^3.2.6"
  }
}
