{
  "name": "openexcel",
  "private": true,
  "version": "0.1.0",
  "description": "OpenExcel - JSON driven multi-sheet Excel workbench",
  "scripts": {
    "dev": "concurrently --raw \"pnpm --filter @openexcel/server dev\" \"pnpm --filter @openexcel/web dev\"",
    "build": "pnpm --filter @openexcel/web build",
    "preview": "pnpm --filter @openexcel/web preview",
    "test": "pnpm --recursive --filter @openexcel/agent --filter @openexcel/core --filter @openexcel/server --filter @openexcel/web test",
    "test:core": "pnpm --filter @openexcel/core test",
    "test:server": "pnpm --filter @openexcel/server test",
    "test:web": "pnpm --filter @openexcel/web test",
    "db:migrate": "pnpm --filter @openexcel/server db:migrate"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
