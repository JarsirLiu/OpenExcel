{
  "name": "openexcel",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.20.0",
  "type": "module",
  "description": "OpenExcel - JSON driven multi-sheet Excel workbench",
  "scripts": {
    "dev": "concurrently --raw \"pnpm --filter @openexcel/server dev\" \"pnpm --filter @openexcel/web dev\"",
    "build": "pnpm --filter @openexcel/web build",
    "preview": "pnpm --filter @openexcel/web preview",
    "test": "pnpm --recursive --filter @openexcel/agent --filter @openexcel/chat-contracts --filter @openexcel/core --filter @openexcel/server --filter @openexcel/web test",
    "test:core": "pnpm --filter @openexcel/core test",
    "test:server": "pnpm --filter @openexcel/server test",
    "test:web": "pnpm --filter @openexcel/web test",
    "db:migrate": "pnpm --filter @openexcel/server db:migrate",
    "db:prepare": "pnpm --filter @openexcel/server db:prepare",
    "check": "biome check --write . && pnpm typecheck",
    "typecheck": "pnpm --recursive --filter @openexcel/agent --filter @openexcel/chat-contracts --filter @openexcel/core --filter @openexcel/server --filter @openexcel/web typecheck",
    "prepare": "husky",
    "changeset": "changeset",
    "version": "changeset version"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,md}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "concurrently": "^10.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8"
  }
}
